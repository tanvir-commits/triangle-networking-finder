# Server-side only — NEVER commit real values
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# Vercel KV (optional — enables cross-device event storage)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Local dev API port
AI_SERVER_PORT=8787

# Frontend build-time default (optional — production also hardcodes this URL)
VITE_API_BASE_URL=https://triangle-networking-finder.vercel.app/api
